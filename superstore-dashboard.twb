      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_3206508107038720]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_3206508107620353]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Order ID])' />
      </column>
      <column caption='YoY Sales Growth' datatype='real' default-format='p0.0%' name='[Calculation_3206508109398018]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Sales]) - LOOKUP(SUM([Sales]), -1)) / ABS(LOOKUP(SUM([Sales]), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='YoY Profit Growth' datatype='real' default-format='p0.0%' name='[Calculation_3206508109680643]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Profit]) - LOOKUP(SUM([Profit]), -1)) / ABS(LOOKUP(SUM([Profit]), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='High Discount Flag' datatype='string' name='[Calculation_3206508119912452]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Discount] &gt;= 0.2 THEN &quot;High Discount&quot; ELSE &quot;Low/No Discount&quot; END' />
      </column>
      <column caption='Discount-Driven Loss' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_3206508120080389]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Discount] &gt;= 0.2 AND [Profit] &lt; 0 &#10;THEN [Profit] &#10;ELSE NULL&#10;END' />
      </column>
